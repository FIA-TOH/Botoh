# FTOH Environment Variables
# Copy this file to .env and fill in your values.
# This single file is used by local backend/frontend/bot bridge commands.

# Local App Configuration
NODE_ENV=development
PORT=3001
BACKEND_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Bot Backend Bridge
# room:local defaults to http://localhost:3001.
# When using Vercel + local pitwall, point this to your public tunnel URL.
BACKEND_WS_URL=http://localhost:3001
BOT_SOCKET_TOKEN=

# Frontend Configuration
# Vercel frontend:
# NEXT_PUBLIC_API_URL=https://your-vercel-app.vercel.app
# NEXT_PUBLIC_PITWALL_API_URL=https://pitwall.your-domain.com
# NEXT_PUBLIC_PITWALL_WS_URL=wss://pitwall.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_PITWALL_API_URL=http://localhost:3001
NEXT_PUBLIC_PITWALL_WS_URL=ws://localhost:3001

# Security
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Database Configuration
# room:local uses the same remote Supabase database when DATABASE_URL points to Supabase.
DATABASE_URL=postgresql://postgres:your-password@db.your-project-id.supabase.co:5432/postgres
DB_HOST=db.your-project-id.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password

# Supabase Configuration
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_API_URL=https://your-project-id.supabase.co
SUPABASE_REST_URL=https://your-project-id.supabase.co/rest/v1/
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Monitoring & Logging
LOG_LEVEL=info
SENTRY_DSN=your-sentry-dsn-for-error-tracking

# Haxball Bot Configuration
HAXBALL_TOKEN=your-haxball-token
LEAGUE_ENV=ftoh
HAXBALL_GEO=BR,-23.5505,-46.6333
LEAGUE_ADMIN_PASSWORD=your-admin-password
PUBLIC_ADMIN_PASSWORD=your-public-admin-password
PUBLIC_MOD_PASSWORD=your-mod-password
BANNED_IPS=[]

# Discord Webhooks
DISCORD_PUBLIC_CHAT_URL=https://discord.com/api/webhooks/your-public-chat-webhook
DISCORD_PUBLIC_LOG_URL=https://discord.com/api/webhooks/your-public-log-webhook
DISCORD_LEAGUE_CHAT_URL=https://discord.com/api/webhooks/your-league-chat-webhook
DISCORD_TRACK_RECORDS_URL=https://discord.com/api/webhooks/your-track-records-webhook
DISCORD_DRIVER_CONTRACT_WEBHOOK_URL=https://discord.com/api/webhooks/your-driver-contract-webhook
