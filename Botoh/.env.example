# Discord Webhook URLs
# Replace these with your actual Discord webhook URLs
# Get these from Discord Server > Integrations > Webhooks > Create Webhook

# Public Host Webhooks
DISCORD_PUBLIC_CHAT_URL=https://discord.com/api/webhooks/webhookid/webhooktoken
DISCORD_PUBLIC_LOG_URL=https://discord.com/api/webhooks/webhookid/webhooktoken
DISCORD_PUBLIC_REPLAY_URL=https://discord.com/api/webhooks/webhookid/webhooktoken

# League Host Webhooks
DISCORD_LEAGUE_CHAT_URL=https://discord.com/api/webhooks/webhookid/webhooktoken
DISCORD_LEAGUE_LOG_URL=https://discord.com/api/webhooks/webhookid/webhooktoken
DISCORD_LEAGUE_REPLAY_URL=https://discord.com/api/webhooks/webhookid/webhooktoken

# Special Purpose Webhooks
DISCORD_TRACK_RECORDS_URL=https://discord.com/api/webhooks/webhookid/webhooktoken
DISCORD_CUT_TRACK_URL=https://discord.com/api/webhooks/webhookid/webhooktoken   

# Community-Specific Webhooks
DISCORD_LEAGUE_REPLAY_URL_HAXBULA=https://discord.com/api/webhooks/webhookid/webhooktoken
DISCORD_GENERAL_CHAT_HAXBULA_URL=https://discord.com/api/webhooks/webhookid/webhooktoken
